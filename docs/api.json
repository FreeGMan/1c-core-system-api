                                            "agentAgreementDate": {
                                                "type": "string",
                                                "format": "date",
                                                "nullable": true,
                                                "description": "Дата агентского договора",
                                                "example": null
                                            },
                                            "agentAgreementNumber": {
                                                "type": "string",
                                                "nullable": true,
                                                "description": "Номер агентского договора",
                                                "example": null
                                            },
                                            "agentCommissionAmount": {
                                                "type": "number",
                                                "nullable": true,
                                                "description": "Сумма агентской комиссии",
                                                "example": null
                                            },
                                            "agentConditionId": {
                                                "type": "string",
                                                "description": "Идентификатор договора с агентом",
                                                "example": "90d04d2b-1601-4a67-a223-b167ea98002d"
                                            },
                                            "agentId": {
                                                "type": "string",
                                                "description": "Идентификатор агента",
                                                "example": "90d04d2b-1601-4a67-a229-b167ea98002d"
                                            },
                                            "agentInn": {
                                                "type": "string",
                                                "nullable": true,
                                                "description": "ИНН агента",
                                                "example": null
                                            },
                                            "agentLegalTypeId": {
                                                "type": "number",
                                                "nullable": true,
                                                "description": "Тип лица агента (ФЛ, ЮЛ, ИП)",
                                                "example": null
                                            },
                                            "agentName": {
                                                "type": "string",
                                                "nullable": true,
                                                "description": "Наименование или ФИО агента",
                                                "example": null
                                            },
                                            "agentPinfl": {
                                                "type": "string",
                                                "nullable": true,
                                                "description": "ПИНФЛ агента",
                                                "example": null
                                            },
                                            "agreementDate": {
                                                "type": "string",
                                                "format": "date",
                                                "description": "Дата заключения договора",
                                                "example": "2026-03-18"
                                            },
                                            "agreementId": {
                                                "type": "string",
                                                "description": "Уникальный ID договора",
                                                "example": "25fede4b-84e3-474b-8b31-ae529584426f"
                                            },
                                            "agreementNumber": {
                                                "type": "string",
                                                "description": "Номер договора",
                                                "example": "PA/001/001/0000000499/26/04/1"
                                            },
                                            "branchCode": {
                                                "type": "string",
                                                "nullable": true,
                                                "description": "Код подразделения",
                                                "example": null
                                            },
                                            "branchId": {
                                                "type": "string",
                                                "nullable": true,
                                                "description": "Идентификатор подразделения",
                                                "example": null
                                            },
                                            "clientId": {
                                                "type": "string",
                                                "description": "Идентификатор клиента",
                                                "example": "e2ccbe13-c238-42c3-9f23-358ff65cdc2c"
                                            },
                                            "clientInn": {
                                                "type": "string",
                                                "nullable": true,
                                                "description": "ИНН клиента",
                                                "example": null
                                            },
                                            "clientLegalType": {
                                                "type": "number",
                                                "description": "Тип лица клиента (например, 3 - физлицос ПИНФЛ)",
