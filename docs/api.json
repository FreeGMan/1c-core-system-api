                                            "policyDeliveryDate": {
                                                "type": "string",
                                                "format": "date",
                                                "description": "Дата выдачи полиса (обычно равен agreementDate)",
                                                "example": "2026-03-18"
                                            },
                                            "policyEndDate": {
                                                "type": "string",
                                                "format": "date",
                                                "description": "Дата окончания действия полиса",
                                                "example": "2028-06-28"
                                            },
                                            "policyLastModifiedDate": {
                                                "type": "string",
                                                "format": "date-time",
                                                "nullable": true,
                                                "description": "Дата последнего изменения",
                                                "example": null
                                            },
                                            "policyNumber": {
                                                "type": "string",
                                                "nullable": true,
                                                "description": "Номер полиса",
                                                "example": null
                                            },
                                            "policySeries": {
                                                "type": "string",
                                                "description": "Серия полиса (серия полисов)",
                                                "example": "00"
