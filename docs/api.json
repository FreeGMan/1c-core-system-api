                                            "paidAmountCurrencyCode": null,
                                            "paidFromClientAccount": null,
                                            "paymentMethodId": 1,
                                            "policyDeliveryDate": "2026-03-18",
                                            "policyEndDate": "2028-06-28",
                                            "policyLastModifiedDate": null,
                                            "policyNumber": null,
                                            "policySeries": "00",
                                            "policyStartDate": "2026-03-18",
                                            "premiumAmount": 60000,
                                            "premiumAmountCurrencyCode": "UZS",
                                            "productCode": "PersonalAccident"
                                        },
                                        "transactionId": "cc2f2e5c-d7d4-47ac-9f55-43407871869b"
