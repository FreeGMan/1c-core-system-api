                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "OperationResult": {
                                            "type": "object",
                                            "properties": {
                                                "errorMessage": {
                                                    "type": "string",
                                                    "description": "Описание ошибки или информационное сообщение (в зависимости от флага result)",
                                                    "example": "Документ проведен: Страховая премия 000000004 от 18.03.2026 0:00:00"
