                                                "result": {
                                                    "type": "number",
                                                    "description": "Флаг ошибки. 0 - если Ок. 1 - если была ошибка",
                                                    "example": 0
                                                }
                                            }
                                        }
                                    }
                                },
                                "examples": {
                                    "succsesful": {
                                        "value": {
                                            "OperationResult": {
                                                "errorMessage": "Документ проведен: Страховая премия 000000004 от 18.03.2026 0:00:00",
                                                "result": 0
                                            }
                                        }
                                    },
                                    "failed": {
                                        "value": {
                                            "OperationResult": {
                                                "errorMessage": "Не заполнено обязательное поле ID агента",
                                                "result": 1
                                            }
