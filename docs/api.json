                                            "clientName": {
                                                "type": "string",
                                                "description": "ФИО или Наименование клиента",
                                                "example": "Ivan214"
                                            },
                                            "clientPinfl": {
                                                "type": "string",
                                                "description": "ПИНФЛ клиента",
                                                "example": "12345678"
