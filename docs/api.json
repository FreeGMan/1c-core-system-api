                                            "insuredAmountCurrencyCode": {
                                                "type": "string",
                                                "description": "Код валюты страховой суммы",
                                                "example": "UZS"
                                            },
                                            "oldAgreementId": {
                                                "type": "string",
                                                "nullable": true,
                                                "description": "ID старого договора (при переносе задолженности)",
                                                "example": null
                                            },
                                            "oldPolicyId": {
                                                "type": "string",
                                                "nullable": true,
                                                "description": "ID старого полиса (при переносе задолженности)",
                                                "example": null
                                            },
                                            "paidAmount": {
                                                "type": "number",
                                                "nullable": true,
                                                "description": "Сумма оплаты",
                                                "example": null
                                            },
                                            "paidAmountCurrencyCode": {
                                                "type": "string",
                                                "nullable": true,
                                                "description": "Код валюты оплаты",
                                                "example": null
