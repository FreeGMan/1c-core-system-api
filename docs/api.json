    "servers": [
        {
            "url": "https://localhost/{baseName}/hs/api"
        }
    ],
    "components": {
        "parameters": {
            "baseName": {
                "name": "baseName",
                "in": "query",
                "required": true,
                "description": "Имя опубликованной базы данных 1С",
                "example": "base-name",
                "schema": {
                    "type": "string"
                }
            }
        }
    },
    "paths": {
        "/agreements/policy/add": {
            "post": {
                "summary": "Добавление / Изменение договоров страхования",
                "description": "",
                "operationId": "AgreementsPolicyAdd",
                "requestBody": {
                    "description": "Данные для создания или изменения договора страхования",
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "policy",
                                    "transactionId"
                                ],
                                "properties": {
                                    "policy": {
                                        "type": "object",
                                        "description": "Объект, содержащий всю информацию по полису",
                                        "required": [
                                            "id",
                                            "agentId",
                                            "agentConditionId",
                                            "agentCommissionAmount",
                                            "agreementId",
                                            "agreementNumber",
                                            "agreementDate",
                                            "branchId",
                                            "clientId",
                                            "clientInn",
                                            "clientPinfl",
                                            "clientName",
                                            "clientLegalType",
                                            "insuranceViewName",
                                            "oldPolicyId",
                                            "paymentMethodId",
                                            "policyDeliveryDate",
                                            "policyEndDate",
                                            "policyNumber",
                                            "policyStartDate",
                                            "policySeries",
                                            "premiumAmountCurrencyCode",
                                            "premiumAmount"
                                        ],
                                        "properties": {
                                            "accountTypeId": {
                                                "type": "string",
                                                "nullable": true,
                                                "description": "Идентификатор типа счета",
                                                "example": null
