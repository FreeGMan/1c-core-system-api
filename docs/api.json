                "responses": {
                    "200": {
                        "description": "Успешное выполнение запроса",
                        "headers": {
                            "content-length": {
                                "schema": {
                                    "type": "string",
                                    "example": "164"
                                }
                            }
                        },
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "required": [
                                        "OperationResult"
                                    ],
                                    "properties": {
                                        "OperationResult": {
                                            "type": "object",
                                            "required": [
                                                "errorMessage",
                                                "result"
                                            ],
                                            "properties": {
                                                "errorMessage": {
                                                    "type": "string",
                                                    "description": "Описание ошибки или информационное сообщение (в зависимости от флага result)",
