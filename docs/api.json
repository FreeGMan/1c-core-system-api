                                                "example": "25fede4b-84e3-474b-8b31-ae529584426f"
                                            },
                                            "insuranceViewName": {
                                                "type": "string",
                                                "description": "Вид страхования (необходим для определения номенклатурнйо группы страхования)",
                                                "example": "ICL Insurance"
